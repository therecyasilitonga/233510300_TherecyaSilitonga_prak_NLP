# LangSmith monitoring — daftar gratis di smith.langchain.com
LANGCHAIN_API_KEY=ls__isi_dengan_api_key_kamu
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=multi-agent-riset-uas

# Model Ollama — sesuaikan dengan yang sudah kamu pull
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# (Opsional) Tavily — jika tidak diisi otomatis pakai DuckDuckGo
TAVILY_API_KEY=tvly_isi_jika_ada
